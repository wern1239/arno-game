generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  password           String
  displayName        String              @default("")
  role               Role                @default(USER)
  createdAt          DateTime            @default(now())
  predictions        Prediction[]
  specialPredictions SpecialPrediction[]
}

enum Role {
  USER
  ADMIN
}

model Match {
  id          String      @id @default(cuid())
  homeTeam    String
  awayTeam    String
  matchDate   DateTime
  homeScore   Int?
  awayScore   Int?
  status      MatchStatus @default(UPCOMING)
  weekNumber  Int
  createdAt   DateTime    @default(now())
  predictions Prediction[]
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Sponsor {
  id        String   @id @default(cuid())
  name      String
  prize     String
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum SpecialQuestionType {
  FINAL_PAIR
  PODIUM
}

model SpecialQuestion {
  id          String              @id @default(cuid())
  type        SpecialQuestionType @unique
  isOpen      Boolean             @default(false)
  deadline    DateTime?
  result1     String?
  result2     String?
  result3     String?
  predictions SpecialPrediction[]
}

model SpecialPrediction {
  id         String          @id @default(cuid())
  userId     String
  questionId String
  answer1    String
  answer2    String?
  answer3    String?
  points     Int             @default(0)
  createdAt  DateTime        @default(now())
  user       User            @relation(fields: [userId], references: [id])
  question   SpecialQuestion @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  points    Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  match     Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
}
